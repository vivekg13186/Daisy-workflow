{
  "name":    "Daisy-workflow Official",
  "version": "1",
  "description": "Local-disk fallback catalog. Used by the marketplace browser in the Plugins admin page when PLUGIN_CATALOG_URL is not set. Mirror the schema below in any remote catalog you publish.",

  "plugins": [
    {
      "name":            "jira",
      "version":         "0.1.0",
      "summary":         "Jira Cloud connector — read / create / update / delete issues, JQL search, comments, transitions. One node, many operations.",
      "category":        "project-management",
      "tags":            ["jira", "atlassian", "issue-tracking", "project-management"],
      "homepage":        "https://github.com/daisy-workflow/plugin-jira",

      "containerImage":  "vivek13186/daisy-plugin-jira:latest",
      "containerPort":   8080,

      "manifestUrl":     "https://raw.githubusercontent.com/daisy-workflow/plugin-jira/main/manifest.json",
      "manifestSha256":  null,

      "catalogEntryUrl": "https://daisy-workflow.example.com/catalog#jira@0.1.0"
    },
    {
      "name":            "google-sheets",
      "version":         "0.1.0",
      "summary":         "Google Sheets connector — read, append, update, clear, delete rows; create or inspect spreadsheets. Auth via Google service-account JSON.",
      "category":        "productivity",
      "tags":            ["google", "google-sheets", "spreadsheet", "productivity"],
      "homepage":        "https://github.com/daisy-workflow/plugin-google-sheet",

      "containerImage":  "vivek13186/daisy-plugin-google-sheets:latest",
      "containerPort":   8080,

      "manifestUrl":     "https://raw.githubusercontent.com/daisy-workflow/plugin-google-sheet/main/manifest.json",
      "manifestSha256":  null,

      "catalogEntryUrl": "https://daisy-workflow.example.com/catalog#google-sheets@0.1.0"
    },
    {
      "name":            "microsoft-teams",
      "version":         "0.1.0",
      "summary":         "Microsoft Teams connector — list teams / channels / chats, create channels, send messages. Auth via Azure AD app registration (client credentials).",
      "category":        "communication",
      "tags":            ["microsoft", "teams", "azure", "chat", "communication"],
      "homepage":        "https://github.com/daisy-workflow/plugin-microsoft-teams",

      "containerImage":  "vivek13186/daisy-plugin-microsoft-teams:latest",
      "containerPort":   8080,

      "manifestUrl":     "https://raw.githubusercontent.com/daisy-workflow/plugin-microsoft-teams/main/manifest.json",
      "manifestSha256":  null,

      "catalogEntryUrl": "https://daisy-workflow.example.com/catalog#microsoft-teams@0.1.0"
    }
  ]
}
