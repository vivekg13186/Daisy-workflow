NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://dag:dag@localhost:5432/dag_engine

# Redis (used by BullMQ + WS pub/sub)
REDIS_URL=redis://localhost:6379

# How many worker concurrency slots in-process
WORKER_CONCURRENCY=4

# --- Authentication ---
# JWT signing secret. Use 32+ random bytes in production. The app refuses
# to issue tokens with the placeholder value when NODE_ENV=production.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me
#
# Token TTLs. Defaults are sane; override only if you need shorter
# windows for compliance.
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=30d
#
# Bootstrap the very first admin from env (only fires on a DB with
# zero users). Useful in CI/CD or first-boot containers. Comment out
# or remove BOOTSTRAP_ADMIN_AUTOCREATE once the user is created — the
# password sitting in env after that is unnecessary risk.
# BOOTSTRAP_ADMIN_AUTOCREATE=true
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=please-change-me
# BOOTSTRAP_WORKSPACE_NAME=Default
#
# OIDC / SSO (optional). When OIDC_ISSUER_URL is set, the login screen
# adds a "Sign in with SSO" button. If unset, only local accounts are
# accepted.
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback
# OIDC_BUTTON_LABEL=Sign in with Google

# --- Configs encryption (KMS envelope) ---
# Daisy stores config secrets (SMTP / DB / API-key fields) using
# envelope encryption: a per-row Data Encryption Key (DEK) is wrapped
# by a Key Encryption Key (KEK) supplied by a KMS provider.
#
# Choose a provider:
#   local — KEK derived from CONFIG_SECRET. No cloud dep, fine for dev.
#   aws   — KEK lives in AWS KMS (HSM-backed). Requires
#           @aws-sdk/client-kms (npm install) plus the env vars below.
KMS_PROVIDER=local
#
# CONFIG_SECRET is the master key for the local provider AND for
# decrypting any rows still on the legacy single-key scheme. Rotate
# this only when migrating off all v1 rows.
CONFIG_SECRET=change-me-to-a-long-random-string
#
# AWS provider only:
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# AWS_REGION=us-east-1
# (auth uses the standard AWS credential chain — IAM role on EC2/ECS/EKS,
#  or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for local prod testing)

# --- AI assistant ("Ask AI" button) ---
# Either set ANTHROPIC_API_KEY (auto-detected as Anthropic provider) ...
# ANTHROPIC_API_KEY=sk-ant-...
# ... or OPENAI_API_KEY (auto-detected as OpenAI provider).
# OPENAI_API_KEY=sk-...
#
# Optional overrides:
# AI_PROVIDER=anthropic|openai
# AI_API_KEY=...               (overrides the per-provider key above)
# AI_MODEL=claude-haiku-4-5-20251001     (or gpt-4o-mini, etc.)
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MAX_TOKENS=2048

# --- Email plugin (email.send) ---
# Standard SMTP transport. Works with Gmail, SES, Mailgun, SendGrid (SMTP relay),
# Postmark, Mailtrap, etc. Per-call override: pass `smtp: {...}` in the node input.
# Set SMTP_HOST=json to use a dry-run "JSON transport" — nothing is sent, the
# rendered envelope is just logged. Useful for tests.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true if using port 465 (implicit TLS)
# SMTP_USER=apikey
# SMTP_PASS=...
# SMTP_FROM="DAG Engine <noreply@example.com>"

# --- File / CSV / Excel plugins ---
# Sandbox root for file.* / csv.* / excel.* plugins. When set, all paths in
# plugin inputs are resolved relative to this directory and any path that
# would escape it is rejected. Strongly recommended for any shared deployment.
# FILE_ROOT=/var/lib/dag-engine/files
