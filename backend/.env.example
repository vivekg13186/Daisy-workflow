NODE_ENV=development
PORT=3000

# Postgres
DATABASE_URL=postgres://dag:dag@localhost:5432/dag_engine

# Redis (used by BullMQ + WS pub/sub)
REDIS_URL=redis://localhost:6379

# How many worker concurrency slots in-process
WORKER_CONCURRENCY=4

# --- Execution resource limits (PR 7) ---
# Wall-clock budgets for the engine. Layered: per-node `timeout` in
# the DSL wins; then workflow-level `timeout` / `nodeTimeout`; then
# these env defaults. Set to empty string to disable a particular
# layer's default (NOT recommended in production — un-bounded runs
# can pin workers indefinitely).
EXECUTION_DEFAULT_NODE_TIMEOUT=60s
EXECUTION_DEFAULT_WORKFLOW_TIMEOUT=30m
# Hard cap on per-node retry attempts. `node.retry` in the DSL is
# clamped to this value, so a copy-pasted `retry: 9999` can't burn
# the queue. Default 10 is well past most legitimate use cases.
EXECUTION_MAX_RETRIES=10
# Maximum fan-out per execution — batch items, batch:true node
# inputs, and workflow.fire children. Default 10k is well above
# legitimate batch sizes; over-cap fails the run up-front.
EXECUTION_MAX_ITERATIONS=10000
# Per-execution token budget for agent / LLM calls. Sum of
# inputTokens + outputTokens across every agent call in the run.
# 0 disables the check. ~100k tokens ≈ a few dollars on most
# providers; tighten for cost-sensitive deployments.
EXECUTION_MAX_TOKENS=100000

# --- Retention (PR 8) ---
# Opt-in so dev environments don't quietly delete executions while
# engineers are debugging. Flip to true in production.
RETENTION_ENABLED=false
# When the daily pass runs. Croner format (5 or 6 fields).
RETENTION_SCHEDULE=0 3 * * *
# RETENTION_TIMEZONE=UTC                    # optional, defaults to local
#
# Per-table windows.
RETENTION_EXECUTIONS_SUCCESS_DAYS=90
RETENTION_EXECUTIONS_FAILED_DAYS=180
RETENTION_REFRESH_TOKENS_DAYS=30
RETENTION_HISTORY_TURNS_PER_CONVERSATION=100
#
# Rows deleted per bounded statement. Higher = fewer transactions
# but longer locks. 50k is comfortable on a healthy Postgres.
RETENTION_BATCH_LIMIT=50000
# How many bounded passes runAll() will chain in one nightly run
# before deferring the rest. 20 × 50k = up to 1M rows per night
# per policy — plenty of headroom even on a freshly-enabled DB.
RETENTION_MAX_PASSES=20

# --- Backups (PR 9) ---
# Used by backend/scripts/backup.sh + the optional docker-compose
# overlay (docker-compose.backup.yml). See wiki/09-backups.md.
#
# Where dumps land locally (a named docker volume in the overlay).
BACKUP_DIR=/var/backups/daisy
# Keep this many recent dumps locally; older ones are pruned each run.
BACKUP_RETENTION_LOCAL=14
# Whether to gzip the custom-format dump after pg_dump. pg_dump
# already compresses internally; gzip on top is a marginal ~5-10%.
BACKUP_GZIP=true
# Optional S3 destination — bucket + prefix. Requires aws CLI on
# whichever host runs backup.sh.
# BACKUP_S3_BUCKET=s3://my-bucket/daisy/
# Optional GPG recipient — encrypts the dump before upload.
# BACKUP_GPG_RECIPIENT=admin@example.com
# Cron schedule for the docker-compose sidecar (5-field).
BACKUP_CRON=0 3 * * *

# --- Authentication ---
# JWT signing secret. Use 32+ random bytes in production. The app refuses
# to issue tokens with the placeholder value when NODE_ENV=production.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=change-me
#
# Token TTLs. Defaults are sane; override only if you need shorter
# windows for compliance.
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_TTL=30d
#
# Bootstrap the very first admin from env (only fires on a DB with
# zero users). Useful in CI/CD or first-boot containers. Comment out
# or remove BOOTSTRAP_ADMIN_AUTOCREATE once the user is created — the
# password sitting in env after that is unnecessary risk.
# BOOTSTRAP_ADMIN_AUTOCREATE=true
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=please-change-me
# BOOTSTRAP_WORKSPACE_NAME=Default
#
# OIDC / SSO (optional). When OIDC_ISSUER_URL is set, the login screen
# adds a "Sign in with SSO" button. If unset, only local accounts are
# accepted.
# OIDC_ISSUER_URL=https://accounts.google.com
# OIDC_CLIENT_ID=...
# OIDC_CLIENT_SECRET=...
# OIDC_REDIRECT_URI=http://localhost:3000/auth/oidc/callback
# OIDC_BUTTON_LABEL=Sign in with Google

# --- Configs encryption (KMS envelope) ---
# Daisy stores config secrets (SMTP / DB / API-key fields) using
# envelope encryption: a per-row Data Encryption Key (DEK) is wrapped
# by a Key Encryption Key (KEK) supplied by a KMS provider.
#
# Choose a provider:
#   local — KEK derived from CONFIG_SECRET. No cloud dep, fine for dev.
#   aws   — KEK lives in AWS KMS (HSM-backed). Requires
#           @aws-sdk/client-kms (npm install) plus the env vars below.
KMS_PROVIDER=local
#
# CONFIG_SECRET is the master key for the local provider AND for
# decrypting any rows still on the legacy single-key scheme. Rotate
# this only when migrating off all v1 rows.
CONFIG_SECRET=change-me-to-a-long-random-string
#
# AWS provider only:
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/abcd-1234
# AWS_REGION=us-east-1
# (auth uses the standard AWS credential chain — IAM role on EC2/ECS/EKS,
#  or AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY for local prod testing)

# --- AI assistant ("Ask AI" button) ---
# Either set ANTHROPIC_API_KEY (auto-detected as Anthropic provider) ...
# ANTHROPIC_API_KEY=sk-ant-...
# ... or OPENAI_API_KEY (auto-detected as OpenAI provider).
# OPENAI_API_KEY=sk-...
#
# Optional overrides:
# AI_PROVIDER=anthropic|openai
# AI_API_KEY=...               (overrides the per-provider key above)
# AI_MODEL=claude-haiku-4-5-20251001     (or gpt-4o-mini, etc.)
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MAX_TOKENS=2048

# --- Email plugin (email.send) ---
# Standard SMTP transport. Works with Gmail, SES, Mailgun, SendGrid (SMTP relay),
# Postmark, Mailtrap, etc. Per-call override: pass `smtp: {...}` in the node input.
# Set SMTP_HOST=json to use a dry-run "JSON transport" — nothing is sent, the
# rendered envelope is just logged. Useful for tests.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false           # true if using port 465 (implicit TLS)
# SMTP_USER=apikey
# SMTP_PASS=...
# SMTP_FROM="DAG Engine <noreply@example.com>"

# --- File / CSV / Excel plugins ---
# Sandbox root for file.* / csv.* / excel.* plugins. When set, all paths in
# plugin inputs are resolved relative to this directory and any path that
# would escape it is rejected. Strongly recommended for any shared deployment.
# FILE_ROOT=/var/lib/dag-engine/files
