{
  "name": "dag-engine-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DAG workflow engine — API, queue worker, plugin runtime",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "migrate": "node src/db/migrate.js",
    "create-admin": "node src/cli/createAdmin.js",
    "retention": "node src/cli/retention.js",
    "install-plugin": "node src/cli/installPlugin.js",
    "test": "node --test --experimental-test-module-mocks test/*.test.js",
    "test:mqtt": "node --test --experimental-test-module-mocks test/mqtt.util.test.js test/mqtt.publish.test.js test/mqtt.trigger.test.js",
    "test:coverage": "node --test --test-concurrency=1 --experimental-test-module-mocks --experimental-test-coverage --test-coverage-include='src/plugins/mqtt/**' --test-coverage-include='src/plugins/builtin/mqtt.publish.js' --test-coverage-include='src/triggers/builtin/mqtt.js' test/mqtt.util.test.js test/mqtt.publish.test.js test/mqtt.trigger.test.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.50.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.53.0",
    "@opentelemetry/resources": "^1.26.0",
    "@opentelemetry/sdk-node": "^0.53.0",
    "@opentelemetry/semantic-conventions": "^1.27.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "croner": "^8.1.2",
    "csv-parse": "^5.5.6",
    "csv-stringify": "^6.5.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "feelin": "^4.0.0",
    "imapflow": "^1.0.171",
    "ioredis": "^5.4.1",
    "jsdom": "^25.0.1",
    "openid-client": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.1",
    "migrate": "^2.1.0",
    "morgan": "^1.10.0",
    "mqtt": "^5.10.1",
    "nodemailer": "^6.9.15",
    "pg": "^8.12.0",
    "rate-limit-redis": "^4.2.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  }
}
